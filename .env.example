# Intervals.icu — legacy per-owner API key fallback
INTERVALS_API_KEY=your-api-key
INTERVALS_ATHLETE_ID=i12345

# Intervals.icu OAuth (see docs/INTERVALS_OAUTH_SPEC.md)
INTERVALS_OAUTH_CLIENT_ID=
INTERVALS_OAUTH_CLIENT_SECRET=
INTERVALS_OAUTH_REDIRECT_URI=https://bot.endurai.me/api/intervals/auth/callback
INTERVALS_WEBHOOK_SECRET=                                                     # shared secret from Intervals.icu → Manage App → Webhook Secret
INTERVALS_WEBHOOK_MONITORING=false                                            # opt-in: set true to forward webhook metadata to Sentry for sampling during a short observability window, then flip back

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_BOT_USERNAME=endurai_bot     # bot username without @, for Telegram Login Widget
TELEGRAM_CHAT_ID=123456789
TELEGRAM_WEBHOOK_URL=                 # base URL without trailing slash (e.g. https://bot.endurai.me); empty = polling mode

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
API_BASE_URL=https://bot.endurai.me   # no trailing slash; serves API + webapp + static + CORS origin
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/triathlon

# Athlete Profile (from HumanGo tests)
ATHLETE_AGE=43
ATHLETE_LTHR_RUN=153
ATHLETE_LTHR_BIKE=153
ATHLETE_MAX_HR=179
ATHLETE_FTP=233
ATHLETE_CSS=141                       # 2:21/100m
ATHLETE_THRESHOLD_PACE_RUN=295        # sec/km, 4:55/km

# Race Goal
GOAL_EVENT_NAME=Ironman 70.3
GOAL_EVENT_DATE=2026-09-15
GOAL_CTL_TARGET=75
GOAL_SWIM_CTL_TARGET=15
GOAL_BIKE_CTL_TARGET=35
GOAL_RUN_CTL_TARGET=25

TIMEZONE=Europe/Belgrade

# HRV Algorithm: "flatt_esco" (default) | "ai_endurance"
HRV_ALGORITHM=flatt_esco

# Web Auth (desktop login via /web bot command)
JWT_SECRET=                           # if empty, uses TELEGRAM_BOT_TOKEN
JWT_EXPIRY_DAYS=7                     # JWT token lifetime in days

# Demo mode: shared password for read-only access to owner's data. Empty = disabled.
DEMO_PASSWORD=

# Strava signature: auto-rename activities with AI-generated promo title/description. Default off.
STRAVA_SIGNATURE_ENABLED=false

# Redis (optional — empty = disabled)
REDIS_URL=redis://localhost:6379/0

# MCP
MCP_AUTH_TOKEN=your-secret-token

# GitHub
GITHUB_TOKEN=ghp_...                  # PAT for issue creation
GITHUB_REPO=radikkhaziev/triathlon-agent

# Sentry (empty DSN = disabled)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=                       # optional, auto-detect from git
